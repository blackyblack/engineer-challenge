{
  "name": "auth-module",
  "version": "1.0.0",
  "description": "Authentication module with DDD, CQRS, gRPC",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest --forceExit --detectOpenHandles",
    "test:domain": "jest tests/domain --forceExit",
    "test:application": "jest tests/application --forceExit",
    "test:integration": "jest tests/integration --forceExit",
    "proto:generate": "grpc_tools_node_protoc --ts_out=grpc_js:src/infrastructure/grpc/generated --js_out=import_style=commonjs,binary:src/infrastructure/grpc/generated --grpc_out=grpc_js:src/infrastructure/grpc/generated -I proto proto/auth.proto",
    "migrate": "ts-node src/infrastructure/persistence/migrate.ts",
    "lint": "eslint src/ tests/ --ext .ts"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.9.14",
    "@grpc/proto-loader": "^0.7.10",
    "argon2": "^0.44.0",
    "jose": "^6.1.3",
    "pg": "^8.11.3",
    "pino": "^8.17.2",
    "prom-client": "^15.1.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.12.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "testcontainers": "^11.12.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  }
}
